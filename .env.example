# Server Configuration
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# LLM Configuration (Groq)
# Get your key at https://console.groq.com/
GROQ_API_KEY=gsk_your_placeholder_key

# Vector Database (Qdrant Cloud)
# Get your cluster URL and API key at https://cloud.qdrant.io/
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key

# Session & History Storage (Supabase)
# Get your project URL and service role key at https://supabase.com/
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key

# Admin Security
# Use a strong secret key for protecting the /ingest and /crawler/ingest routes
ADMIN_API_KEY=your-super-secret-admin-key

# JWT Security (Internal user auth if needed)
SECRET_KEY=912d08a59489f61b0a8f89e27c1cd8d8a7c2f1f0a8d7e6c5b4a3f2e1d0c9b8a7
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
